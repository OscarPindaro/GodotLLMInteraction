; Engine configuration file.
; Test project for open_rpg_4_7_0 scene fixtures.
; These scenes are from gdquest-demos/godot-open-rpg at commit b70df69
; ("Update Godot version to 4.6.2"), MIT licensed.
; No 4.7-specific commit exists in open-rpg; scenes are identical to 4.6.2.

config_version=5

[application]

config/name="open_rpg_4_7_0_test_fixtures"
config/features=PackedStringArray("4.7", "GL Compatibility")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[filesystem]

import/blender/enabled=false
import/fbx/enabled=false
