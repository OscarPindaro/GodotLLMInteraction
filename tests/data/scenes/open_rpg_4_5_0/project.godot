; Engine configuration file.
; Test project for open_rpg_4_5_0 scene fixtures.
; These scenes are from gdquest-demos/godot-open-rpg at commit 7619659
; ("Upgrade to Godot 4.5 & fix Dialogic portraits"), MIT licensed.

config_version=5

[application]

config/name="open_rpg_4_5_0_test_fixtures"
config/features=PackedStringArray("4.5", "GL Compatibility")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[filesystem]

import/blender/enabled=false
import/fbx/enabled=false
